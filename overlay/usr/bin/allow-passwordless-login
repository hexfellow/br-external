#!/bin/sh
set -e

TARGET_FILE="/etc/default/dropbear"
TMP_FILE=$(mktemp)

if mountpoint -q "$TARGET_FILE"; then
  umount "$TARGET_FILE"
fi

awk '/^DROPBEAR_ARGS=/ {$0 = $0 " -B"} {print}' "$TARGET_FILE" > "$TMP_FILE"
mount --bind "$TMP_FILE" "$TARGET_FILE"
systemctl restart dropbear

echo "Passwordless login for root is enabled, until next reboot"
